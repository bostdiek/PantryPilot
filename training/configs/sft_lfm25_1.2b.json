{
  "base_model": "unsloth/LFM2.5-1.2B-Instruct",
  "compute": "gpu-cluster",
  "enable_dapt": false,
  "enable_grpo": false,
  "sft_data": "azureml:pantrypilot-sft-data:3",
  "val_data": "azureml:pantrypilot-sft-data-val:3",
  "sft": {
    "max_seq_length": 4096,
    "learning_rate": 2e-4,
    "num_epochs": 3,
    "batch_size": 1,
    "gradient_accumulation_steps": 16,
    "warmup_steps": 10,
    "lora_r": 16,
    "lora_alpha": 32,
    "no_4bit": true,
    "chat_template": "native",
    "logging_steps": 10,
    "eval_steps": 100,
    "save_steps": 100,
    "seed": 3407
  }
}
