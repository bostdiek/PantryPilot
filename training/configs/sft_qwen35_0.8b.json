{
  "base_model": "unsloth/Qwen3.5-0.8B",
  "compute": "gpu-cluster",
  "enable_dapt": false,
  "enable_grpo": false,
  "sft_data": "azureml:pantrypilot-sft-data:3",
  "val_data": "azureml:pantrypilot-sft-data-val:3",
  "sft": {
    "max_seq_length": 8192,
    "learning_rate": 2e-4,
    "num_epochs": 3,
    "batch_size": 2,
    "gradient_accumulation_steps": 4,
    "warmup_steps": 10,
    "lora_r": 16,
    "lora_alpha": 16,
    "chat_template": "native",
    "no_4bit": true,
    "load_in_16bit": true,
    "logging_steps": 10,
    "eval_steps": 100,
    "save_steps": 100,
    "seed": 3407
  }
}
